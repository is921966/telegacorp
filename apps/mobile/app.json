{
  "expo": {
    "name": "Telegram Corp",
    "slug": "telegram-corp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "telegramcorp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.telegramcorp.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Нужен доступ к камере для отправки фото и видео",
        "NSMicrophoneUsageDescription": "Нужен доступ к микрофону для голосовых сообщений",
        "NSPhotoLibraryUsageDescription": "Нужен доступ к галерее для отправки фото и видео",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-router", { "root": "./app" }],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Нужен доступ к галерее для отправки фото и видео",
          "cameraPermission": "Нужен доступ к камере для отправки фото и видео"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
